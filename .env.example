# Crypto TG Alert Bot Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# TELEGRAM CONFIGURATION (Required)
# =============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=your_user_id_here

# =============================================================================
# BINANCE API CONFIGURATION (Optional but recommended for higher rate limits)
# =============================================================================
# Create API keys at https://www.binance.com/en/my/settings/api-management
# Note: These are optional - the bot works with public API endpoints
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Environment: development, production, test
NODE_ENV=production

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# Database file path (SQLite)
DATABASE_PATH=./data/crypto-tgalert.db

# =============================================================================
# OPTIONAL ADVANCED SETTINGS
# =============================================================================
# API request timeout in milliseconds
API_TIMEOUT=10000

# Request rate limiting (requests per minute)
RATE_LIMIT=60

# Max concurrent API requests
MAX_CONCURRENT_REQUESTS=5

# =============================================================================
# ESP32 语音推送（可选） —— 通过 ouyu-v2 device-gateway
# =============================================================================
# 不设置则 ESP32 功能整体禁用。
# OUYU_GATEWAY_URL: ouyu-v2 HTTP 推送入口
#   - 公网 80 端口走杭州 nginx 反代（已配置 IP 白名单，仅允许 Singapore 访问）
#   - 内部 device-gateway 实际监听 127.0.0.1:18003，不对外直连
# OUYU_DEVICE_ID: 绑定的 ESP32 MAC 地址（招福角色对应设备）
OUYU_GATEWAY_URL=http://47.111.161.136
OUYU_DEVICE_ID=94:a9:90:29:00:44